#!/usr/bin/env perl

use strict;
use warnings;

use FindBin qw($Bin);
use lib "$Bin/../lib";

use ArpCLI::Client;
use ArpCLI::Error;
use ArpCLI::Output;
use ArpCLI::Plans::Format;
use ArpCLI::CLI::Args;
use ArpCLI::CLI::Format;
use ArpCLI::Util qw(is_uuid flatten_os_templates format_specs format_bytes display_width);

sub usage {
    print <<'USAGE';
usage: arpcli [-c config] <command> [arguments]

Most read commands accept --json to print the API response body (or an
aggregated list envelope for paginated resources).

read commands:
  status [--range 30d] [--brief] [--json]   discover account services
  servers list [--json]
  servers show <uuid> [--json]
  servers bandwidth <uuid> [--range 30d] [--json]
  servers billing <uuid> [--json]
  servers ssh-host-keys <uuid> [--json]
  locations [list] [--json]
  plans [list] [--json] [--thunder]
  isos [list] [--json]
  os-templates [list] [--json]
  dns-records list [--json]
  ssh-keys list [--json]

write commands (require write-scoped API key; --json prints API body):
  dns-records create <ip_address> <hostname> [--json]
  dns-records update <id> <hostname> [--json]
  dns-records delete <id> [--json]
  ssh-keys create <name> <username> <key> [--json]
  ssh-keys delete <id> [--json]
  servers delete <uuid> [--json]
  servers boot|shutdown|poweroff|reset <uuid> [--json]
  servers change-iso <uuid> <iso_file> [--json]
  servers set-parameter <uuid> <param> <value> [--json]

options:
  -c path    configuration file (default: ~/.config/arpcli/conf)
  -v         verbose (warn before rate-limit sleeps)
  -h         show this help
USAGE
    exit ($ENV{__ARPCLI_TEST_EXIT} // 0);
}

sub main {
    my @args = @ARGV;
    my $config_path;
    while (@args && $args[0] =~ /^-/) {
        my $opt = shift @args;
        if ($opt eq '-h' || $opt eq '--help') {
            usage();
        }
        elsif ($opt eq '-c') {
            die "arpcli: -c requires a path\n" unless @args;
            $config_path = shift @args;
        }
        elsif ($opt eq '-v' || $opt eq '--verbose') {
            $ENV{ARPCLI_VERBOSE} = 1;
        }
        else {
            die "arpcli: unknown option: $opt\n";
        }
    }

    unless (@args) {
        if (defined $config_path) {
            ArpCLI::Client->new(config_path => $config_path);
        }
        usage();
    }
    my $command = shift @args;

    my $client = ArpCLI::Client->new(
        defined $config_path ? (config_path => $config_path) : (),
    );

    if ($command eq 'status') {
        return cmd_status($client, @args);
    }

    return run_resource($client, $command, @args);
}

sub cmd_status {
    my ($client, @args) = @_;
    my $json  = ArpCLI::CLI::Args::extract_json(\@args);
    my $brief = ArpCLI::CLI::Args::extract_brief(\@args);
    my $range = ArpCLI::CLI::Args::extract_range(\@args);
    ArpCLI::CLI::Args::ensure_empty(\@args, 'status');
    my $data = $client->discover(
        bandwidth_range => $range,
        brief           => $brief,
    );
    if ($json) {
        ArpCLI::CLI::Format::print_json($data);
        return 0;
    }
    ArpCLI::Output->new->print_discovery($data, brief => $brief);
    return 0;
}

sub run_resource {
    my ($client, $command, @args) = @_;

    if ($command eq 'servers') {
        return cmd_servers($client, @args);
    }
    if ($command eq 'locations') {
        return cmd_locations($client, @args);
    }
    if ($command eq 'plans') {
        return cmd_plans($client, @args);
    }
    if ($command eq 'isos') {
        return cmd_isos($client, @args);
    }
    if ($command eq 'os-templates') {
        return cmd_os_templates($client, @args);
    }
    if ($command eq 'dns-records') {
        return cmd_dns_records($client, @args);
    }
    if ($command eq 'ssh-keys') {
        return cmd_ssh_keys($client, @args);
    }

    die "arpcli: unknown command: $command\n";
}

sub cmd_servers {
    my ($client, @args) = @_;
    die "arpcli: servers requires a subcommand\n" unless @args;
    my $sub = shift @args;

    if ($sub eq 'list') {
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'servers list');
        if ($json) {
            ArpCLI::CLI::Format::print_json($client->servers->list_raw);
            return 0;
        }
        my $servers = $client->servers->list;
        print_table([qw(LABEL UUID STATE PLAN IPv4)], $servers, sub {
            my ($s) = @_;
            ($s->{label}, $s->{uuid}, $s->{state}, $s->{plan}, $s->{primary_ipv4} // '-');
        });
        return 0;
    }

    if ($sub eq 'show') {
        my $uuid = shift @args or die "arpcli: servers show requires <uuid>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'servers show');
        if ($json) {
            ArpCLI::CLI::Format::print_json($client->servers->show_raw($uuid));
            return 0;
        }
        my $server = $client->servers->show($uuid);
        for my $key (sort keys %$server) {
            my $val = $server->{$key};
            if (ref $val eq 'ARRAY') {
                print "$key=", format_specs($val), "\n" if $key eq 'specs';
                next;
            }
            print "$key=", (defined $val ? $val : 'n/a'), "\n";
        }
        return 0;
    }

    if ($sub eq 'bandwidth') {
        my $uuid = shift @args or die "arpcli: servers bandwidth requires <uuid>\n";
        my $json  = ArpCLI::CLI::Args::extract_json(\@args);
        my $range = ArpCLI::CLI::Args::extract_range(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'servers bandwidth');
        if ($json) {
            ArpCLI::CLI::Format::print_json(
                $client->servers->bandwidth_raw($uuid, range => $range),
            );
            return 0;
        }
        my $bw = $client->servers->bandwidth($uuid, range => $range);
        for my $key (qw(range inbound_bytes outbound_bytes total_bytes)) {
            my $val = $bw->{$key};
            $val = format_bytes($val) if $key =~ /bytes\z/ && defined $val;
            print "$key=", (defined $val ? $val : 'n/a'), "\n";
        }
        return 0;
    }

    if ($sub eq 'billing') {
        my $uuid = shift @args or die "arpcli: servers billing requires <uuid>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'servers billing');
        if ($json) {
            ArpCLI::CLI::Format::print_json($client->servers->billing_raw($uuid));
            return 0;
        }
        my $bill = $client->servers->billing($uuid);
        for my $key (sort keys %$bill) {
            my $val = $bill->{$key};
            if (ref $val eq 'ARRAY') {
                print "$key=[", scalar(@$val), " items]\n";
                next;
            }
            print "$key=", (defined $val ? $val : 'n/a'), "\n";
        }
        return 0;
    }

    if ($sub eq 'ssh-host-keys') {
        my $uuid = shift @args or die "arpcli: servers ssh-host-keys requires <uuid>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'servers ssh-host-keys');
        if ($json) {
            ArpCLI::CLI::Format::print_json($client->servers->ssh_host_keys_raw($uuid));
            return 0;
        }
        my $keys = $client->servers->ssh_host_keys($uuid);
        for my $k (@$keys) {
            print "$k->{type}\t$k->{fingerprint}\n";
        }
        return 0;
    }

    if ($sub =~ /\A(?:boot|shutdown|poweroff|reset)\z/) {
        my $uuid = shift @args or die "arpcli: servers $sub requires <uuid>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, "servers $sub");
        my $res = $client->actions->$sub($uuid);
        return _print_action_result($res, $json);
    }

    if ($sub eq 'change-iso') {
        my $uuid = shift @args or die "arpcli: servers change-iso requires <uuid> <iso_file>\n";
        my $iso  = shift @args or die "arpcli: servers change-iso requires <uuid> <iso_file>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'servers change-iso');
        my $res = $client->actions->change_iso($uuid, $iso);
        return _print_action_result($res, $json);
    }

    if ($sub eq 'set-parameter') {
        my $uuid  = shift @args or die "arpcli: servers set-parameter requires <uuid> <param> <value>\n";
        my $param = shift @args or die "arpcli: servers set-parameter requires <uuid> <param> <value>\n";
        my $value = shift @args or die "arpcli: servers set-parameter requires <uuid> <param> <value>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'servers set-parameter');
        my $res = $client->actions->set_parameter($uuid, $param, $value);
        return _print_action_result($res, $json);
    }

    if ($sub eq 'delete') {
        my $uuid = shift @args or die "arpcli: servers delete requires <uuid>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'servers delete');
        my $res = $client->servers->delete($uuid);
        if ($json) {
            ArpCLI::CLI::Format::print_json($res->{data} // { status => 'deleted' });
            return 0;
        }
        print "status=$res->{data}{status}\n" if ref $res->{data} eq 'HASH' && $res->{data}{status};
        print "deleted\n";
        return 0;
    }

    die "arpcli: unknown servers subcommand: $sub\n";
}

sub _print_action_result {
    my ($res, $json) = @_;
    if ($json) {
        ArpCLI::CLI::Format::print_json($res->{data} // {});
        return 0;
    }
    print "status=$res->{data}{status}\n" if ref $res->{data} eq 'HASH' && $res->{data}{status};
    return 0;
}

sub cmd_plans {
    my ($client, @args) = @_;
    ArpCLI::CLI::Args::extract_list_subcommand(\@args, 'plans');

    my $json    = ArpCLI::CLI::Args::extract_json(\@args);
    my $thunder = ArpCLI::CLI::Args::extract_thunder(\@args);
    ArpCLI::CLI::Args::ensure_empty(\@args, 'plans list');

    my $data = $client->plans->list_raw;
    if ($thunder) {
        my $plans = $data->{plans};
        $data->{plans} = [
            grep { (($_->{code} // '') =~ /\Athunder_/i) } @{ ref $plans eq 'ARRAY' ? $plans : [] }
        ];
    }

    if ($json) {
        ArpCLI::CLI::Format::print_json($data);
        return 0;
    }

    ArpCLI::Plans::Format::print_grouped(\*STDOUT, $data->{plans} // []);
    return 0;
}

sub cmd_locations {
    my ($client, @args) = @_;
    ArpCLI::CLI::Args::extract_list_subcommand(\@args, 'locations');
    my $json = ArpCLI::CLI::Args::extract_json(\@args);
    ArpCLI::CLI::Args::ensure_empty(\@args, 'locations list');
    if ($json) {
        ArpCLI::CLI::Format::print_json($client->locations->list_raw);
        return 0;
    }
    for my $loc (@{ $client->locations->list }) {
        print join("\t", map { defined $loc->{$_} ? $loc->{$_} : '' } sort keys %$loc), "\n";
    }
    return 0;
}

sub cmd_isos {
    my ($client, @args) = @_;
    ArpCLI::CLI::Args::extract_list_subcommand(\@args, 'isos');
    my $json = ArpCLI::CLI::Args::extract_json(\@args);
    ArpCLI::CLI::Args::ensure_empty(\@args, 'isos list');
    if ($json) {
        ArpCLI::CLI::Format::print_json($client->isos->list_raw);
        return 0;
    }
    for my $iso (sort @{ $client->isos->list }) {
        print "$iso\n";
    }
    return 0;
}

sub cmd_os_templates {
    my ($client, @args) = @_;
    ArpCLI::CLI::Args::extract_list_subcommand(\@args, 'os-templates');
    my $json = ArpCLI::CLI::Args::extract_json(\@args);
    ArpCLI::CLI::Args::ensure_empty(\@args, 'os-templates list');
    if ($json) {
        ArpCLI::CLI::Format::print_json($client->os_templates->list_raw);
        return 0;
    }
    my $templates = flatten_os_templates($client->os_templates->list);
    print_table([qw(CODE FAMILY VERSION)], $templates, sub {
        my ($t) = @_;
        ($t->{code}, $t->{family}, $t->{version});
    });
    return 0;
}

sub cmd_dns_records {
    my ($client, @args) = @_;
    die "arpcli: dns-records requires a subcommand\n" unless @args;
    my $sub = shift @args;
    if ($sub eq 'list') {
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'dns-records list');
        if ($json) {
            ArpCLI::CLI::Format::print_json($client->dns_records->list_raw);
            return 0;
        }
        my $records = $client->dns_records->list;
        print_table([qw(ID NAME CONTENT DOMAIN)], $records, sub {
            my ($r) = @_;
            ($r->{id}, $r->{name}, $r->{content}, $r->{domain});
        });
        return 0;
    }
    if ($sub eq 'create') {
        my $ip = shift @args or die "arpcli: dns-records create requires <ip_address> <hostname>\n";
        my $host = shift @args or die "arpcli: dns-records create requires <ip_address> <hostname>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'dns-records create');
        my $rec = $client->dns_records->create({
            ip_address => $ip,
            hostname   => $host,
        });
        return _print_dns_record($rec, $json);
    }
    if ($sub eq 'update') {
        my $id = shift @args or die "arpcli: dns-records update requires <id> <hostname>\n";
        my $host = shift @args or die "arpcli: dns-records update requires <id> <hostname>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'dns-records update');
        my $rec = $client->dns_records->update($id, { hostname => $host });
        return _print_dns_record($rec, $json);
    }
    if ($sub eq 'delete') {
        my $id = shift @args or die "arpcli: dns-records delete requires <id>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'dns-records delete');
        my $res = $client->dns_records->delete($id);
        if ($json) {
            ArpCLI::CLI::Format::print_json($res->{data} // { status => 'deleted' });
            return 0;
        }
        print "deleted\n";
        return 0;
    }
    die "arpcli: unknown dns-records subcommand: $sub\n";
}

sub _print_dns_record {
    my ($rec, $json) = @_;
    if ($json) {
        ArpCLI::CLI::Format::print_json({ dns_record => $rec });
        return 0;
    }
    for my $key (sort keys %$rec) {
        my $val = $rec->{$key};
        print "$key=", (defined $val ? $val : 'n/a'), "\n";
    }
    return 0;
}

sub cmd_ssh_keys {
    my ($client, @args) = @_;
    die "arpcli: ssh-keys requires a subcommand\n" unless @args;
    my $sub = shift @args;
    if ($sub eq 'list') {
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'ssh-keys list');
        if ($json) {
            ArpCLI::CLI::Format::print_json($client->ssh_keys->list_raw);
            return 0;
        }
        my $keys = $client->ssh_keys->list;
        print_table([qw(ID NAME USERNAME TYPE)], $keys, sub {
            my ($k) = @_;
            ($k->{id}, $k->{name}, $k->{username} // '-', $k->{key_type});
        });
        return 0;
    }
    if ($sub eq 'create') {
        my $name = shift @args or die "arpcli: ssh-keys create requires <name> <username> <key>\n";
        my $user = shift @args or die "arpcli: ssh-keys create requires <name> <username> <key>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        my $key = join(' ', @args);
        die "arpcli: ssh-keys create requires <name> <username> <key>\n" unless length $key;
        my $rec = $client->ssh_keys->create({
            name     => $name,
            username => $user,
            key      => $key,
        });
        return _print_ssh_key($rec, $json);
    }
    if ($sub eq 'delete') {
        my $id = shift @args or die "arpcli: ssh-keys delete requires <id>\n";
        my $json = ArpCLI::CLI::Args::extract_json(\@args);
        ArpCLI::CLI::Args::ensure_empty(\@args, 'ssh-keys delete');
        my $res = $client->ssh_keys->delete($id);
        if ($json) {
            ArpCLI::CLI::Format::print_json($res->{data} // { status => 'deleted' });
            return 0;
        }
        print "deleted\n";
        return 0;
    }
    die "arpcli: unknown ssh-keys subcommand: $sub\n";
}

sub _print_ssh_key {
    my ($key, $json) = @_;
    if ($json) {
        ArpCLI::CLI::Format::print_json({ ssh_key => $key });
        return 0;
    }
    for my $field (sort keys %$key) {
        my $val = $key->{$field};
        print "$field=", (defined $val ? $val : 'n/a'), "\n";
    }
    return 0;
}

sub print_table {
    my ($headers, $rows, $extract) = @_;
    my @data = map { [ $extract->($_) ] } @$rows;
    my @widths;
    for my $i (0 .. $#$headers) {
        my $w = display_width($headers->[$i]);
        for my $row (@data) {
            my $len = display_width($row->[$i] // '');
            $w = $len if $len > $w;
        }
        push @widths, $w;
    }
    print join(' ', map { _pad_cell($headers->[$_], $widths[$_]) } 0 .. $#$headers), "\n";
    for my $row (@data) {
        print join(' ', map {
            _pad_cell($row->[$_] // '', $widths[$_])
        } 0 .. $#$headers), "\n";
    }
}

sub _pad_cell {
    my ($text, $width) = @_;
    $text //= '';
    my $pad = $width - display_width($text);
    $pad = 0 if $pad < 0;
    return $text . (' ' x $pad);
}

eval {
    my $code = main();
    exit ($code // 0);
};
if (my $err = $@) {
    if (ref $err eq 'ArpCLI::Error') {
        print STDERR "arpcli: ", $err->message, "\n";
        exit 1;
    }
    die $err;
}